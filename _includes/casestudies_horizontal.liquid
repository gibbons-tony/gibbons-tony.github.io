<!-- Horizontal Case Study Card -->
<div class="col mb-4">
  <a href="{{ casestudy.url | relative_url }}">
    <div class="card h-100 hoverable">
      <div class="row no-gutters">
        {% if casestudy.img %}
          <div class="col-md-5">
            {% include figure.liquid
              loading="eager"
              path=casestudy.img
              sizes="(min-width: 768px) 300px, 50vw"
              alt="case study image"
              class="card-img"
            %}
          </div>
        {% endif %}
        <div class="{% if casestudy.img %}col-md-7{% else %}col-md-12{% endif %}">
          <div class="card-body">
            <h3 class="card-title">{{ casestudy.title }}</h3>

            {% if casestudy.category %}
              <span class="badge badge-pill badge-secondary mb-2">{{ casestudy.category }}</span>
            {% endif %}

            <p class="card-text">{{ casestudy.summary }}</p>

            {% if casestudy.metrics %}
              <div class="mt-3">
                <div class="row">
                  {% for metric in casestudy.metrics limit:3 %}
                    <div class="col-6 mb-2">
                      <strong class="text-primary d-block">{{ metric.value }}</strong>
                      <small class="text-muted">{{ metric.label }}</small>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
