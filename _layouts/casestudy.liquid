---
layout: default
---
{% if page._styles %}
  <!-- Case Study style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>

    {% if page.category %}
      <p class="post-meta">
        <span class="badge badge-pill badge-primary">{{ page.category }}</span>
      </p>
    {% endif %}
  </header>

  <article class="casestudy-content">
    {% if page.img %}
      <div class="row mt-3">
        <div class="col-sm mt-3 mt-md-0">
          {% include figure.liquid path=page.img class="img-fluid rounded z-depth-1" zoomable=true %}
        </div>
      </div>
    {% endif %}

    {{ content }}

    {% if page.related_project %}
      <div class="mt-5 pt-4 clearfix" style="border-top: 1px solid var(--global-divider-color);">
        <h3>Technical Implementation</h3>
        <p>For detailed technical implementation, architecture, and code, see the <a href="{{ page.related_project }}">related project page</a>.</p>
      </div>
    {% endif %}
  </article>

  {% comment %}
  Bibliography disabled for GitHub Pages compatibility
  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      bibliography tag removed for GitHub Pages
    </div>
  {% endif %}
  {% endcomment %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}

  <div class="mt-5">
    <a href="/casestudies/" class="btn btn-sm z-depth-0" role="button">
      <i class="fa-solid fa-arrow-left"></i> Back to Case Studies
    </a>
  </div>
</div>
